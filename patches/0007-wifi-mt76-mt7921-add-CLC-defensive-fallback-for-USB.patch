From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: mt7921u-ai <patch-engineer@mt7921u.local>
Date: Fri, 2 May 2026 00:00:00 +0000
Subject: [PATCH] wifi: mt76: mt7921: add CLC defensive fallback for USB

Patch 6 enabled CLC for USB by removing the mt76_is_usb() skip, but
there is no guarantee that the firmware's MCU_CE_CMD(SET_CLC) actually
works over USB bulk transport. If SET_CLC is rejected or times out,
mt7921_load_clc() propagates the error up to mt7921_run_firmware(),
causing complete device initialization failure -- the adapter becomes
unusable even for 2.4/5 GHz operation.

Add a self-defensive fallback: when SET_CLC fails on USB, log a
dev_warn() with the error code, set clc_chan_conf = 0x00 (conservative:
no 6 GHz channels), and return 0 so the device can still operate on
2.4/5 GHz bands. PCIe and SDIO paths are completely unaffected since
the fallback is gated on mt76_is_usb().

Add a clc_force_usb module parameter (default 0). When set to 1, the
fallback is disabled and SET_CLC errors propagate normally on USB,
allowing testers to confirm whether the firmware accepts SET_CLC over
USB and observe the raw error code.

Add dev_dbg() dynamic debug traces at key CLC points:
- Entry to mt7921_load_clc() (fw_name, bus type)
- Before each __mt7921_mcu_set_clc() call (idx, alpha2)
- After successful CLC load
- In the fallback path

The FIXME comment marks the need for the vendor driver's alternative
regulatory path (CMD_ID_CAL_BACKUP_IN_HOST_V2 + rlmDomainGetChnlList)
which uses a different command interface for USB CLC configuration.

Signed-off-by: mt7921u-ai <patch-engineer@mt7921u.local>
---
 .../net/wireless/mediatek/mt76/mt7921/mcu.c  | 43 ++++++++++++++++++-
 1 file changed, 42 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/mediatek/mt76/mt7921/mcu.c b/drivers/net/wireless/mediatek/mt76/mt7921/mcu.c
index abcdef6..789abcde 100644
--- a/drivers/net/wireless/mediatek/mt76/mt7921/mcu.c
+++ b/drivers/net/wireless/mediatek/mt76/mt7921/mcu.c
@@ -14,6 +14,11 @@ static bool mt7921_disable_clc;
 module_param_named(disable_clc, mt7921_disable_clc, bool, 0644);
 MODULE_PARM_DESC(disable_clc, "disable CLC support");

+static bool clc_force_usb;
+module_param_named(clc_force_usb, clc_force_usb, bool, 0644);
+MODULE_PARM_DESC(clc_force_usb, "force CLC SET command on USB even if previously failed");
+
 int mt7921_mcu_parse_response(struct mt76_dev *mdev, int cmd,
 			      struct sk_buff *skb, int seq)
 {
@@ -423,6 +428,14 @@ static int mt7921_load_clc(struct mt792x_dev *dev, const char *fw_name)
 	int ret, i, len, offset = 0;
 	u8 *clc_base = NULL, hw_encap = 0;

+	dev_dbg(mdev->dev, "load_clc: fw_name=%s bus=%s\n",
+		fw_name, mt76_is_usb(mdev) ? "USB" :
+			 mt76_is_sdio(mdev) ? "SDIO" : "MMIO");
+
+	if (clc_force_usb)
+		dev_info(mdev->dev,
+			 "CLC force USB mode enabled - SET_CLC errors will propagate\n");
+
 	dev->phy.clc_chan_conf = 0xff;
 	if (mt7921_disable_clc)
 		return 0;
@@ -490,7 +503,24 @@ static int mt7921_load_clc(struct mt792x_dev *dev, const char *fw_name)
 		}
 	}
+	dev_dbg(mdev->dev, "load_clc: calling mt7921_mcu_set_clc\n");
 	ret = mt7921_mcu_set_clc(dev, "00", ENVIRON_INDOOR);
+
+	/* Self-defensive fallback for USB: if SET_CLC fails over USB
+	 * bulk transport, conservatively disable 6 GHz and continue.
+	 * PCIe/SDIO paths remain unaffected.
+	 */
+	if (ret && mt76_is_usb(mdev) && !clc_force_usb) {
+		dev_warn(mdev->dev,
+			 "CLC SET failed on USB (err=%d); CLC unavailable over USB, "
+			 "falling back to conservative channel config\n", ret);
+		/* FIXME: port vendor CMD_ID_CAL_BACKUP_IN_HOST_V2 + rlmDomainGetChnlList() */
+		dev->phy.clc_chan_conf = 0x00;
+		dev_warn(mdev->dev,
+			 "6 GHz disabled until vendor CLC path is ported\n");
+		ret = 0;
+	} else if (!ret) {
+		dev_dbg(mdev->dev, "load_clc: CLC loaded successfully\n");
+	}
 out:
 	release_firmware(fw);

@@ -1404,8 +1434,15 @@ int mt7921_mcu_set_clc(struct mt792x_dev *dev, u8 *alpha2,

 	/* submit all clc config */
 	for (i = 0; i < ARRAY_SIZE(phy->clc); i++) {
+		dev_dbg(dev->mt76.dev, "set_clc: idx=%d alpha2=%c%c\n",
+			i, alpha2[0], alpha2[1]);
 		ret = __mt7921_mcu_set_clc(dev, alpha2, env_cap,
 					   phy->clc[i], i);

 		/* If no country found, set "00" as default */
-		if (ret == -ENOENT)
+		if (ret == -ENOENT) {
+			dev_dbg(dev->mt76.dev,
+				"set_clc: idx=%d no match, retrying with alpha2=00\n", i);
 			ret = __mt7921_mcu_set_clc(dev, "00",
 						   ENVIRON_INDOOR,
 						   phy->clc[i], i);
+		}
 		if (ret < 0)
 			return ret;
--
2.47.0
