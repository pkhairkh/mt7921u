+void mt7921_twt_debugfs_remove(struct mt792x_dev *dev);
 
 /* CSI (Channel State Information) — TASK-008 */
 #define MT7921_CSI_RING_SIZE            1000
diff --git a/drivers/net/wireless/mediatek/mt76/mt7921/twt.c b/drivers/net/wireless/mediatek/mt76/mt7921/twt.c
index dae0934..41dc26b 100644
--- a/drivers/net/wireless/mediatek/mt76/mt7921/twt.c
+++ b/drivers/net/wireless/mediatek/mt76/mt7921/twt.c
@@ -260,3 +260,31 @@ void mt7921_twt_teardown_sta(struct mt792x_dev *dev,
 			mt7921_twt_teardown_flow(dev, msta, i);
 	}
 }
