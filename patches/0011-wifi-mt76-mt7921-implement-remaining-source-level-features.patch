 #include "mt76_connac_mcu.h"
 #include "mt792x_regs.h"
 
+/* TASK-018: Per-Chunk Firmware ACK option.
+ * When enabled, set BIT(31) (DOWNLOAD_CONFIG_ACK_OPTION) in the
+ * firmware download config command to request per-chunk ACK from
+ * firmware. This mirrors the vendor driver's
+ * CFG_ENABLE_FW_DOWNLOAD_ACK / DOWNLOAD_CONFIG_ACK_OPTION mechanism.
+ */
+static bool fw_ack_enable;
+module_param_named(fw_ack_enable, fw_ack_enable, bool, 0644);
+MODULE_PARM_DESC(fw_ack_enable, "Enable per-chunk firmware download ACK (default: 0)");
+
 int mt76_connac_mcu_start_firmware(struct mt76_dev *dev, u32 addr, u32 option)
 {
 	struct {
@@ -3083,6 +3093,12 @@ static u32 mt76_connac2_get_data_mode(struct mt76_dev *dev, u32 info)
 		dev_err(dev->dev, "Encryption type not support!\n");
 	}
 
+	/* TASK-018: Per-Chunk Firmware ACK.
+	 * RUNTIME_VERIFY: verify firmware download succeeds with ACK enabled
+	 */
+	if (fw_ack_enable)
+		dev_info(dev->dev,
+			 "Firmware download ACK mode enabled (per-chunk ACK)\n");
+
 	return mode;
 }
 
